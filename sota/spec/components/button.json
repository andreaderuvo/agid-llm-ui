{
  "id": "button",
  "tag": "it-button",
  "class": "ItButton",
  "intent": "Bottone per un'azione dell'utente",
  "props": {
    "variant":  { "type": "enum", "values": ["primary", "secondary", "outline", "success", "danger", "warning"], "default": "primary" },
    "size":     { "type": "enum", "values": ["sm", "md", "lg"], "default": "md" },
    "type":     { "type": "enum", "values": ["button", "submit"], "default": "button" },
    "disabled": { "type": "boolean", "default": false }
  },
  "slot": "Etichetta del bottone",
  "render": "<button type=\"{{attr type}}\"{{flag disabled}}>{{slot}}</button>",
  "a11yGuard": "requires-label-if-empty",
  "a11y": [
    "Emette sempre un <button> nativo (mai <div> cliccabili)",
    "Se privo di testo (solo icona) richiede aria-label",
    "Indicatore di focus sempre visibile"
  ],
  "forbidden": ["div-cliccabile", "tailwind", "onclick-inline"],
  "example": "<it-button variant=\"outline\">Annulla</it-button>"
}
