{
  "id": "drawer",
  "tag": "it-drawer",
  "runtime": "zag",
  "poweredBy": "@zag-js/dialog",
  "intent": "Pannello off-canvas (menu laterale, filtri) che scivola da un lato",
  "props": {
    "trigger": {
      "type": "string",
      "default": "Apri"
    },
    "title": {
      "type": "string",
      "default": "Pannello"
    },
    "side": {
      "type": "enum",
      "values": [
        "left",
        "right"
      ],
      "default": "left"
    }
  },
  "slot": "Contenuto del pannello",
  "a11y": [
    "role=dialog + focus-trap + ESC + backdrop (da Zag)",
    "Alla chiusura il focus torna al trigger",
    "Blocco dello scroll di sfondo mentre è aperto"
  ],
  "forbidden": [
    "pannello-senza-focus-trap"
  ],
  "style": ".agid-drawer-positioner{position:fixed;inset:0;display:flex;z-index:1500} .agid-drawer-right{justify-content:flex-end} .agid-drawer{pointer-events:auto;background:#fff;height:100dvh;width:min(320px,85vw);box-shadow:0 0 40px rgba(0,0,0,.3);padding:var(--it-space-md);overflow:auto;display:flex;flex-direction:column} .agid-drawer-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--it-space-md)} .agid-drawer-title{margin:0;font-size:1.2rem;color:var(--it-color-text)} .agid-drawer-close{border:0;background:transparent;font-size:1.6rem;line-height:1;cursor:pointer;color:var(--it-color-text)}",
  "example": "<it-drawer trigger=\"Apri menu laterale\" side=\"left\" title=\"Menu\">\n  <it-linklist>\n    <a href=\"#\">Anagrafe</a>\n    <a href=\"#\">Tributi</a>\n    <a href=\"#\">Servizi scolastici</a>\n  </it-linklist>\n</it-drawer>"
}
