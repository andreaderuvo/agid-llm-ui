{
  "$description": "Design token in formato W3C DTCG. Unica fonte per colori/spazi/tipografia.",
  "color": {
    "primary":         { "$type": "color", "$value": "#0066CC" },
    "primary-hover":   { "$type": "color", "$value": "#004d99" },
    "on-primary":      { "$type": "color", "$value": "#ffffff" },
    "text":            { "$type": "color", "$value": "#17324d" },
    "muted":           { "$type": "color", "$value": "#5a6772" },
    "border":          { "$type": "color", "$value": "#c5d2dc" },
    "focus":           { "$type": "color", "$value": "#ff9900" },
    "info-bg":         { "$type": "color", "$value": "#e3f2fd" },
    "info-accent":     { "$type": "color", "$value": "#0066CC" },
    "warning-bg":      { "$type": "color", "$value": "#fff6e0" },
    "warning-accent":  { "$type": "color", "$value": "#8a5200" },
    "success-bg":      { "$type": "color", "$value": "#e6f4ea" },
    "success-accent":  { "$type": "color", "$value": "#2e7d32" }
  },
  "space": {
    "xs": { "$type": "dimension", "$value": "4px" },
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "24px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "8px" }
  },
  "font": {
    "base": { "$type": "fontFamily", "$value": "'Titillium Web', system-ui, -apple-system, sans-serif" }
  }
}
